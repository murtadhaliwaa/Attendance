generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id             String        @id @default(cuid())
  employeeCode   String        @unique
  name           String
  // department: نسخة نصية متزامنة (denormalized) من departmentRef.name.
  // المصدر الموثوق هو departmentId/departmentRef؛ ويبقى هذا الحقل متطابقاً
  // معه دائماً لأن كل عمليات الكتابة تمرّ عبر resolveEmployeeDepartment.
  // نحتفظ به للأداء (قراءة بدون JOIN) ولدعم السجلات القديمة (departmentId = null).
  department     String
  departmentId   String?
  departmentRef  Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position       String
  phone          String?
  faceDescriptor    Float[]
  faceDescriptorVersion Int           @default(2)
  hasFaceRegistered Boolean       @default(false)
  emergencyCode  String        @unique
  shiftId        String?
  shift          WorkSchedule? @relation(fields: [shiftId], references: [id])
  customEndTime  String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  attendances    Attendance[]

  @@index([isActive])
  @@index([shiftId])
  @@index([department])
  @@index([departmentId])
  @@index([name])
  @@index([isActive, shiftId])
  @@index([isActive, hasFaceRegistered])
}

model Attendance {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime  @db.Date
  checkIn    DateTime?
  checkOut   DateTime?
  status     Status    @default(PRESENT)
  // طريقة التسجيل لكل حدث على حدة (قد يحضر بالوجه وينصرف بالرمز الطارئ أو العكس).
  checkInMethod          Method?
  checkOutMethod         Method?
  checkInSupervisorId    String?
  checkInSupervisor      ShiftSupervisor? @relation("CheckInSupervisor", fields: [checkInSupervisorId], references: [id], onDelete: SetNull)
  checkInSupervisorName  String?
  checkOutSupervisorId   String?
  checkOutSupervisor     ShiftSupervisor? @relation("CheckOutSupervisor", fields: [checkOutSupervisorId], references: [id], onDelete: SetNull)
  checkOutSupervisorName String?
  overtime   Int?
  notes      String?
  createdAt  DateTime  @default(now())

  @@unique([employeeId, date])
  @@index([date])
  @@index([status])
  @@index([date, status])
  @@index([date, checkIn(sort: Desc)])
  @@index([date, employeeId])
  @@index([checkInSupervisorId])
  @@index([checkOutSupervisorId])
}

// مسؤولو الشفتات — لكل مسؤول رمز طارئ خاص يعمل على كل الموظفين.
// يختار المسؤول اسم الموظف ويُدخل رمزه لتسجيل حضور/انصراف ذلك الموظف،
// ويُحفظ في السجل مَن قام بالتسجيل (للمساءلة في التقارير).
model ShiftSupervisor {
  id            String       @id @default(cuid())
  name          String
  emergencyCode String       @unique
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  checkInAttendances  Attendance[] @relation("CheckInSupervisor")
  checkOutAttendances Attendance[] @relation("CheckOutSupervisor")

  @@index([isActive])
}

model WorkSchedule {
  id                String     @id @default(cuid())
  name              String
  startTime         String
  endTime           String
  lateAfter         Int        @default(0)
  earlyLeaveBefore  Int        @default(0)
  isDefault         Boolean    @default(false)
  employees         Employee[]
  createdAt         DateTime   @default(now())

  @@index([isDefault])
}

model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model SystemUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(MANAGER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alert {
  id           String    @id @default(cuid())
  type         AlertType
  employeeId   String
  employeeName String
  message      String
  isRead       Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([isRead, createdAt(sort: Desc)])
}

model RateLimit {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime

  @@index([resetAt])
}

enum Status {
  PRESENT
  ABSENT
  LATE
  EARLY_LEAVE
}

enum Method {
  FACE
  EMERGENCY_CODE
  MANUAL
}

enum Role {
  MANAGER
  INQUIRY_CLERK
}

enum AlertType {
  LATE
  ABSENT
  OVERTIME
}
